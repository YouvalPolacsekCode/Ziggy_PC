# --- Python ---
.venv/
env/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.log
*.log.*

# --- Node.js (frontend) ---
node_modules/
web_interface/frontend/node_modules/
*.tsbuildinfo
*.lock
npm-debug.log
yarn-error.log

# --- Environment & secrets ---
.env
.env.*
!.env.example
config/gmail_credentials.json
config/gmail_token.json
config/settings.yaml
config/secrets.yaml
user_files/auth.db
user_files/auth.db-*
# Everything under user_files/ is runtime state — devices, events, layouts,
# mobile pairings, presence zones, etc. The .gitkeep marker keeps the
# directory alive for fresh checkouts. Add !user_files/<name> below only for
# files a fresh checkout genuinely needs (none today).
user_files/*
!user_files/.gitkeep

# --- VS Code / IDEs ---
.vscode/
.idea/

# --- OS clutter ---
.DS_Store
Thumbs.db

# --- Build / cache ---
dist/
build/
coverage/
.cache/
*.bak
*.swp

# --- Frontend build folders ---
web_interface/frontend/.next/
web_interface/frontend/.turbo/

# --- Mongo (if using dumps) ---
dump/
*.bson
*.json

.gstack/

# --- Stray runtime state created when CWD is the frontend dir ---
# Real runtime files live in the top-level user_files/.
frontend/user_files/

# --- Dev HA runtime state ---
# docker/ha-config-dev/ holds the Mac dev HA's config. Keep the seed
# files (configuration.yaml, automations.yaml, etc.) but ignore the
# runtime DB, logs, .storage, and onboarding token state — they're
# regenerated on first boot.
docker/ha-config-dev/.storage/
docker/ha-config-dev/.cloud/
docker/ha-config-dev/deps/
docker/ha-config-dev/tts/
docker/ha-config-dev/blueprints/
docker/ha-config-dev/custom_components/
docker/ha-config-dev/.HA_VERSION
docker/ha-config-dev/.uuid
docker/ha-config-dev/home-assistant.log*
docker/ha-config-dev/home-assistant_v2.db*
docker/ha-config-dev/secrets.yaml
