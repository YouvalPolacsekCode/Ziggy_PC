# image/compose/versions.env — SINGLE SOURCE OF TRUTH for pinned component
# versions across the beta fleet. ziggy-image-device.sh reads these (or their
# env overrides) and writes them into each hub's /opt/ziggy/.env, which
# docker-compose.prod.yml consumes.
#
# Keep in lockstep with what dev validated (docker/ha-config-dev/.HA_VERSION).
# Bump deliberately + re-run the canary suite before shipping a new pin.

HA_VERSION=2026.6.1
MOSQUITTO_VERSION=2.0.20
Z2M_VERSION=2.1.1

# Image digests (pin-by-digest for byte-reproducibility). Populate by resolving
# each tag once, then reference these instead of tags for a locked fleet:
#   docker buildx imagetools inspect ghcr.io/home-assistant/home-assistant:2026.6.1
# HA_DIGEST=ghcr.io/home-assistant/home-assistant@sha256:REPLACE
# MOSQUITTO_DIGEST=eclipse-mosquitto@sha256:REPLACE
# Z2M_DIGEST=koenkk/zigbee2mqtt@sha256:REPLACE
