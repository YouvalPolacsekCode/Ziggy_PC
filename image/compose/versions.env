# image/compose/versions.env — SINGLE SOURCE OF TRUTH for pinned component
# versions across the beta fleet. ziggy-image-device.sh reads these (or their
# env overrides) and writes them into each hub's /opt/ziggy/.env, which
# docker-compose.prod.yml consumes.
#
# Keep in lockstep with what dev validated (docker/ha-config-dev/.HA_VERSION).
# Bump deliberately + re-run the canary suite before shipping a new pin.

HA_VERSION=2026.6.1
MOSQUITTO_VERSION=2.0.20
Z2M_VERSION=2.1.1

# Image digests (pin-by-digest for byte-reproducibility). Reference these
# instead of the tags above for a locked fleet. Resolved 2026-07-12 from the
# tags above via `docker buildx imagetools inspect <img>` (the "Digest:" line is
# the manifest digest — the value that goes after image@sha256:).
#
# To re-resolve on a connected host after a version bump:
#   docker buildx imagetools inspect ghcr.io/home-assistant/home-assistant:${HA_VERSION}
#   docker buildx imagetools inspect eclipse-mosquitto:${MOSQUITTO_VERSION}
#   docker buildx imagetools inspect koenkk/zigbee2mqtt:${Z2M_VERSION}
HA_DIGEST=ghcr.io/home-assistant/home-assistant@sha256:59aa8824955c9db491b75d2eebe42bd68494f80c2ec69ec0d66d9dae37d37514
MOSQUITTO_DIGEST=eclipse-mosquitto@sha256:21421af7b32bf9ce508e9090c8eb13bb81f410ca778dc205506180a6f862d0eb
Z2M_DIGEST=koenkk/zigbee2mqtt@sha256:c7b111384716247f057b449ebb242bf05f3fafb98dd6d5688c1ac1fc730d5e95
